# Copy to .env and fill in your actual values
# .env is gitignored — never commit secrets

# Required for the agent layer (week 7+)
ANTHROPIC_API_KEY=sk-ant-xxx

# Optional: Space-Track.org credentials for high-precision ephemerides
SPACETRACK_USERNAME=
SPACETRACK_PASSWORD=

# Optional: cost caps
DAILY_LLM_BUDGET_USD=15
PER_IP_QUERIES_PER_DAY=30

# Optional: model selection
ANTHROPIC_MODEL_PRIMARY=claude-sonnet-4-6
ANTHROPIC_MODEL_FAST=claude-haiku-4-5
